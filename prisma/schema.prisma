generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  CUSTOMER
  ADMIN
  SUPPORT
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentType {
  JAZZCASH
  EASYPAISA
  COD
  CARD
}

// --- USER MANAGEMENT ---

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String?
  role           Role      @default(CUSTOMER)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  // --- NEW SECURITY FIELDS ---
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String? // Stores the secret key for Google Authenticator
  
  resetToken     String?
  resetTokenExpiry DateTime?

  // Relations
  orders         Order[]
  wishlist       WishlistItem[] 
  reviews        Review[]
  addresses      Address[]
  paymentMethods PaymentMethod[] 
}

// --- PRODUCT CATALOG ---

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Decimal  @default(0)
  stock       Int
  category    String
  
  // Inventory Fields
  sku         String?  @unique // Stock Keeping Unit
  brand       String?
  barcode     String?  // UPC / EAN
  qrCode      String?  // Internal QR ID
  costPrice   Decimal? @default(0)
  taxRate     Float?   @default(0)
  minStock    Int      @default(10) 
  unit        String?  @default("pcs")
  tags        String?  
  
  vendor      String?
  origin      String   @default("Local") 
  expiryDate  DateTime?

  images      ProductImage[] 
  orderItems  OrderItem[] 
  wishlistedBy WishlistItem[]
  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt        
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// --- ORDER SYSTEM ---

model Order {
  id              String        @id @default(uuid())
  
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  
  // Shipping Details
  guestName       String
  guestEmail      String       
  address         String
  city            String
  postalCode      String
  phone           String
  
  status          OrderStatus   @default(PENDING)
  totalAmount     Decimal
  
  paymentMethod   PaymentType 
  paymentPhone    String?    
  transactionId   String?    
  isPaid          Boolean       @default(false)
  
  // Coupon Relation
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])

  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Decimal
}

// --- USER DASHBOARD ---

model Address {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fullName   String
  street     String
  city       String
  postalCode String
  country    String   @default("Pakistan")
  phone      String
  isDefault  Boolean  @default(false)
}

model PaymentMethod {
  id         String   @id @default(uuid())
  type       String   
  last4      String   
  expiry     String   
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- MARKETING & REVIEWS ---

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      
  comment   String?  
  
  images    String[] // Stores URLs of uploaded images
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

// --- COUPON SYSTEM (Fixed & Merged) ---

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  discount    Float     // Supports 10.5 or 50.00
  type        String    @default("PERCENT") // Options: "PERCENT" or "FIXED"
  minAmount   Float     @default(0)         // Min cart total required
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  // Relations
  orders      Order[]   
}

// --- CAREERS / JOBS (Updated for Advanced Form) ---

model Job {
  id              String    @id @default(uuid())
  title           String
  department      String    
  type            String    
  location        String    
  salary          String    
  description     String
  requirements    String    // Stored as JSON String
  
  // Advanced Fields
  experienceLevel String?   
  workplaceType   String?   
  contactEmail    String?
  deadline        DateTime?
  skills          String?   // Stored as JSON String (Tags)

  isActive        Boolean   @default(true)
  featured        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// --- BLOG SYSTEM ---

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String
  coverImage  String?
  author      String   @default("E-Com Team")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}